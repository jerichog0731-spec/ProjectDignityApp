{
  "name": "project-dignity-app",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jerichog0731-spec/ProjectDignityApp.git"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "electron .",
    "electron:build": "next build && electron-builder --win"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "qrcode.react": "^4.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.projectdignityhobbs.app",
    "productName": "Project Dignity Hobbs C.O.R.E.",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Project Dignity Hobbs C.O.R.E."
    },
    "publish": [
      {
        "provider": "github",
        "owner": "jerichog0731-spec",
        "repo": "ProjectDignityApp"
      }
    ]
  }
}

